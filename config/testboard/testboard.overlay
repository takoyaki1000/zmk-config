#include <dt-bindings/zmk/matrix_transform.h>
/* ZMK Studio無効時は physical_layouts.dtsi が悪影響を及ぼす場合があるため、
   エラーが出るようなら一時的に以下の include をコメントアウトしてください */
#include <physical_layouts.dtsi>
#include "testboard-layouts.dtsi"

/ {
    /* --- 追加: ZMKの基盤設定 --- */
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix-transform = &default_transform;
    };

    /* 最小限の変換定義 (1x1) */
    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <1>;
        rows = <1>;
        map = <RC(0,0)>;
    };

    /* ダミーのキースキャン定義（エラー回避用） */
    kscan0: kscan {
        compatible = "zmk,kscan-gpio-direct";
        input-gpios = <&xiao_d 0 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
    };
    /* -------------------------- */
};

&pinctrl {
    spi0_default: spi0_default {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 0, 5)>,
                    <NRF_PSEL(SPIM_MOSI, 0, 4)>,
                    <NRF_PSEL(SPIM_MISO, 0, 4)>;
        };
    };

    spi0_sleep: spi0_sleep {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 0, 5)>,
                    <NRF_PSEL(SPIM_MOSI, 0, 4)>,
                    <NRF_PSEL(SPIM_MISO, 0, 4)>;
            low-power-enable;
        };
    };
};

&spi0 {
    status = "okay";
    pinctrl-0 = <&spi0_default>;
    pinctrl-1 = <&spi0_sleep>; // sleep用も指定
    pinctrl-names = "default", "sleep"; // "sleep"を追加
    cs-gpios = <&xiao_d 3 GPIO_ACTIVE_LOW>;

    trackball: pmw3320@0 {
        compatible = "pixart,pmw3320";
        reg = <0>;
        spi-max-frequency = <2000000>;
        irq-gpios = <&xiao_d 6 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
        status = "okay";
    };
};

/ {
    trackball_listener {
        compatible = "zmk,input-listener";
        device = <&trackball>;
    };
};